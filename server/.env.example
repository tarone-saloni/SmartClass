
# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Email (Gmail) ────────────────────────────────────────────────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
# Cookie max-age in milliseconds (7 days = 604800000)
JWT_COOKIE_MAX_AGE=604800000
COOKIE_NAME=sc_token

# ─── OTP ──────────────────────────────────────────────────────────────────────
# OTP expiry in milliseconds (5 min = 300000)
OTP_EXPIRES_MS=300000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Anthropic / AI ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
AI_MODEL=claude-sonnet-4-6

# Per-function max_tokens for LLM calls
AI_MAX_TOKENS_DEFAULT=2000
AI_MAX_TOKENS_QUIZ=3000
AI_MAX_TOKENS_SUMMARIZE=1500
AI_MAX_TOKENS_EXPLAIN=1500
AI_MAX_TOKENS_GRADE=1500
AI_MAX_TOKENS_SCHEDULE=2500
AI_MAX_TOKENS_PERFORMANCE=1500
AI_MAX_TOKENS_OUTLINE=3500

# Agentic workflow
AI_AGENT_MAX_TOKENS=4096
AI_AGENT_MAX_ITERATIONS=10

# ─── Cloudinary (Media Uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── File Uploads ─────────────────────────────────────────────────────────────
# Recording max size in bytes (2 GB = 2147483648)
RECORDING_MAX_SIZE_BYTES=2147483648

NOTIFICATION_LIMIT=50
DASHBOARD_UPCOMING_LIMIT=5

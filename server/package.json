{
  "name": "smartclass-server",
  "version": "1.0.0",
  "description": "SmartClass LMS — Express 5 + MongoDB backend with real-time Socket.IO support",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:shell": "bash test.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/SmartClass.git"
  },
  "keywords": [
    "lms",
    "education",
    "express",
    "mongodb",
    "socket.io"
  ],
  "author": "SmartClass",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  }
}

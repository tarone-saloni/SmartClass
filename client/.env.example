# ─── Backend URL ──────────────────────────────────────────────────────────────
# Full URL of the backend — used by all API calls and socket connections
VITE_API_URL=http://localhost:5000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get your Google Client ID from https://console.cloud.google.com/
# Create OAuth 2.0 credentials -> Web Application
# Add your domain to Authorized JavaScript origins
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── WebRTC STUN Servers ──────────────────────────────────────────────────────
# Comma-separated list of STUN server URLs
VITE_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# ─── Storage Keys ─────────────────────────────────────────────────────────────
VITE_STORAGE_USER_KEY=smartclass_user
VITE_STORAGE_THEME_KEY=smartclass_theme
